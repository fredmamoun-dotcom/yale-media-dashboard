# ─── Anthropic API ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Email Configuration (SMTP) ──────────────────────────────────
# Gmail example — use an App Password, not your login password
# For other providers: Outlook, SendGrid, AWS SES, etc., adjust accordingly
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ─── Email Recipients ────────────────────────────────────────────
# Comma-separated list of email addresses to receive the report
EMAIL_RECIPIENTS=leader1@yale.edu,leader2@yale.edu

# From address shown on the email
EMAIL_FROM="Yale OPAC Media Monitor" <media-monitor@yale.edu>

# ─── Schedule ─────────────────────────────────────────────────────
# Cron expressions for the two daily runs (default: 7:00 AM and 7:00 PM ET)
CRON_MORNING=0 7 * * *
CRON_EVENING=0 19 * * *

# Timezone for cron
CRON_TIMEZONE=America/New_York

# ─── Server ───────────────────────────────────────────────────────
PORT=3000
